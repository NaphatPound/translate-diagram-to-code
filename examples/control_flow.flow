# if / else / unless, ternary, postfix-if, each, while, break/continue.
x = 7

if x > 0
  p "positive"
else
  p "non-positive"

# Compact: ternary expression + assignment.
label = x % 2 == 0 ? "even" : "odd"
p f"x is {label}"

# Postfix-if on a single statement.
p "is small" if x < 10

# Postfix-unless.
p "non-empty" unless count([]) > 0

# each over a range with break/continue.
each i in 1..10
  continue unless i % 2 == 0       # skip odd
  break if i > 6                    # stop after 6
  p i

# while with compound assignment.
n = 0; i = 1
while i <= 4
  n += i
  i += 1
p f"sum 1..4 = {n}"
