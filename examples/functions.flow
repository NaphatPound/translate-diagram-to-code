# def with positional + default args, implicit return, recursion, multi-return.
# The last bare expression in a def body becomes the return value.
def double x
  x * 2

def scale x factor=2
  x * factor

def fact n
  if n <= 1
    return 1                         # explicit return inside a branch
  n * fact(n - 1)                    # implicit return as the last stmt

def minmax xs
  [min(*xs), max(*xs)]

p double(5)             # 10
p scale(5)              # 10  (default factor=2)
p scale(5, 4)           # 20
p fact(6)               # 720

lo, hi = minmax([3, 1, 4, 1, 5, 9, 2, 6])
p f"range: {lo}..{hi}"
