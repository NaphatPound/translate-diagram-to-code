# String operations: methods, slice, f-string, concat.
# F-string placeholders are full Flow expressions — they compile to the
# target language's native interpolation form, so `count()` becomes `len()`
# in Python, etc.

s = "  Hello, World!  "
clean = s.strip()
upper = clean.upper()
p f"len={count(upper)}, first={upper[0..4]}, last={upper[7..11]}"

# Concat with `+` plus a method chain inside an f-string.
parts = clean.split(",")
p f"first part: {parts[0].strip()}"

# Simple template with two interpolations.
name = "alice"; age = 30
p f"hi {name}, age {age}"
