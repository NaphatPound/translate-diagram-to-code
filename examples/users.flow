# Fetch users from API, keep adults, summarize, save report.
when start
  http_get "https://api.example.com/users" -> users
  filter from=users where="x['age'] >= 18" -> adults
  n = count(adults)

  if n > 0
    summarize adults -> summary
    w file="report.txt" text=summary
    p "saved"
  else
    p "no adults"

  each user in adults
    p f"hi {user.name}, age {user.age}"
